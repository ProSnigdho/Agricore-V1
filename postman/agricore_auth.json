						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@agricore.com\",\n    \"password\": \"adminpassword\",\n    \"role\": \"admin\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/login/",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"auth",
								"login",
								""
							]
						},
						"description": "Login with email and password to receive JWT tokens."
					},
					"response": []
				},
				{
